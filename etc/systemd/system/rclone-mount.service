[Unit]
Description=Rclone Mount
AssertPathIsDirectory=/mnt/shared/gdrive
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/default/calc-server
ExecStart=/usr/bin/rclone mount axc: /mnt/shared/gdrive --vfs-cache-mode writes --links --config /home/$LOCAL_USER/.config/rclone/rclone.conf --allow-other
ExecStop=/bin/fusermount -u /mnt/shared/gdrive
Restart=always
RestartSec=10

[Install]
WantedBy=default.target