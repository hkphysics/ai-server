#!/usr/bin/env bash
set -euo pipefail

[[ $# -ne 1 ]] && { echo "Usage: $0 <username>" >&2; exit 1; }

USERNAME="$1"

[[ ! "$USERNAME" =~ ^[a-z_][a-z0-9_@.-]*$ ]] && { echo "Error: Invalid username format." >&2; exit 1; }

ADMIN=0
[[ -n "${ADMIN_USERS:-}" ]] && [[ "$ADMIN_USERS" =~ (^|[[:space:],])${USERNAME}([[:space:],]|$) ]] && ADMIN=1

getent group jupyterhub-admin >/dev/null 2>&1 || groupadd jupyterhub-admin

if ! id "$USERNAME" >/dev/null 2>&1; then
    echo "Creating user '$USERNAME'..."
    useradd -m -c "" -g users -s /bin/bash --badname "$USERNAME" || { echo "User '$USERNAME' creation failed." >&2; exit 1; }
    echo "User '$USERNAME' created successfully."
fi

[[ "$ADMIN" == "1" ]] && { echo "Adding user '$USERNAME' to admin group"; usermod -aG jupyterhub-admin "$USERNAME"; }

echo "User info:"
id "$USERNAME"
